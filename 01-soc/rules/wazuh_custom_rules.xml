<group name="custom_soc,windows,">

  <!-- ===== AD ATTACKS (wazuh_ad_attacks) ===== -->

  <rule id="100001" level="15">
    <if_group>sysmon_event10</if_group>
    <field name="win.eventdata.targetImage" type="pcre2">(?i)\\lsass\.exe</field>
    <field name="win.eventdata.grantedAccess" type="pcre2">0x1010|0x1410|0x1fffff|0x143a</field>
    <description>CRITICAL: LSASS Memory Access - Credential Dumping (T1003.001)</description>
    <mitre><id>T1003.001</id></mitre>
    <group>credential_access,lsass,</group>
  </rule>

  <rule id="100091" level="0">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.sourceImage" type="pcre2">(?i)(antimalware|werfault|csrss)</field>
    <description>False positive: Legitimate LSASS access</description>
  </rule>

  <rule id="100002" level="13">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4769$</field>
    <field name="win.eventdata.ticketEncryptionType">^0x17$</field>
    <description>HIGH: Kerberos RC4 Ticket - Possible Kerberoasting (T1558.003)</description>
    <mitre><id>T1558.003</id></mitre>
    <group>credential_access,kerberoasting,</group>
  </rule>

  <rule id="100092" level="15" frequency="5" timeframe="60">
    <if_matched_sid>100002</if_matched_sid>
    <same_source_ip />
    <description>CRITICAL: Multiple Kerberos RC4 requests - Active Kerberoasting</description>
    <mitre><id>T1558.003</id></mitre>
    <group>credential_access,kerberoasting,</group>
  </rule>

  <rule id="100003" level="15">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4662$</field>
    <field name="win.eventdata.properties" type="pcre2">1131f6aa-9c07-11d1-f79f-00c04fc2dcd2|1131f6ad-9c07-11d1-f79f-00c04fc2dcd2</field>
    <description>CRITICAL: DCSync Attack - DS Replication Rights Used (T1003.006)</description>
    <mitre><id>T1003.006</id></mitre>
    <group>credential_access,dcsync,</group>
  </rule>

  <rule id="100004" level="14">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4624$</field>
    <field name="win.eventdata.logonType">^3$</field>
    <field name="win.eventdata.authenticationPackageName" type="pcre2">^NTLM$</field>
    <field name="win.eventdata.keyLength">^0$</field>
    <description>HIGH: Possible Pass-the-Hash - NTLM Network Logon (T1550.002)</description>
    <mitre><id>T1550.002</id></mitre>
    <group>lateral_movement,pass_the_hash,</group>
  </rule>

  <rule id="100010" level="10">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)(certutil|mshta|regsvr32|rundll32|wscript|cscript|installutil|regasm)\.exe</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(http|https|download|urlcache|encode|\.ps1|\.hta)</field>
    <description>HIGH: LOLBin with suspicious arguments (T1218)</description>
    <mitre><id>T1218</id></mitre>
    <group>defense_evasion,lolbins,</group>
  </rule>

  <rule id="100020" level="12">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4624$</field>
    <field name="win.eventdata.logonType">^3$</field>
    <field name="win.eventdata.processName" type="pcre2">(?i)wsmprovhost</field>
    <description>HIGH: WinRM Session - Possible Lateral Movement (T1021.006)</description>
    <mitre><id>T1021.006</id></mitre>
    <group>lateral_movement,winrm,</group>
  </rule>

  <rule id="100030" level="11">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4698$</field>
    <description>MEDIUM: Scheduled Task Created - Possible Persistence (T1053.005)</description>
    <mitre><id>T1053.005</id></mitre>
    <group>persistence,scheduled_task,</group>
  </rule>

  <rule id="100040" level="9">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4672$</field>
    <field name="win.eventdata.privileges" type="pcre2">SeDebugPrivilege|SeTcbPrivilege|SeImpersonatePrivilege</field>
    <description>MEDIUM: High Privilege Token Assigned (T1078.002)</description>
    <mitre><id>T1078.002</id></mitre>
    <group>privilege_escalation,</group>
  </rule>

  <rule id="100050" level="12">
    <if_group>sysmon_event13</if_group>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)(CurrentVersion\\Run|CurrentVersion\\RunOnce)</field>
    <field name="win.eventdata.details" type="pcre2">(?i)(\.exe|\.dll|\.ps1|\.bat|cmd\.exe|powershell)</field>
    <description>HIGH: Registry Run Key Modified - Persistence (T1547.001)</description>
    <mitre><id>T1547.001</id></mitre>
    <group>persistence,registry,</group>
  </rule>

  <rule id="100060" level="14">
    <if_group>sysmon_event8</if_group>
    <field name="win.eventdata.targetImage" type="pcre2">(?i)(explorer|svchost|notepad|mspaint)\.exe</field>
    <description>HIGH: Remote Thread in System Process - Process Injection (T1055)</description>
    <mitre><id>T1055</id></mitre>
    <group>defense_evasion,process_injection,</group>
  </rule>

  <rule id="100070" level="13">
    <if_sid>60103</if_sid>
    <field name="win.system.eventID">^4720$</field>
    <description>HIGH: New User Account Created - Verify Authorization (T1136)</description>
    <mitre><id>T1136</id></mitre>
    <group>persistence,account_manipulation,</group>
  </rule>

  <rule id="100080" level="14">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(Set-MpPreference|DisableRealtimeMonitoring|sc\.exe.*stop.*defender|taskkill.*defender)</field>
    <description>CRITICAL: Attempt to Disable Security Tools (T1562.001)</description>
    <mitre><id>T1562.001</id></mitre>
    <group>defense_evasion,disable_security,</group>
  </rule>

  <!-- ===== LATERAL MOVEMENT (wazuh_lateral_movement) ===== -->

  <rule id="100200" level="11">
    <if_group>windows</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)net\s+use\s+\\\\</field>
    <description>Lateral Movement: net use to remote admin share (T1021.002)</description>
    <mitre><id>T1021.002</id></mitre>
    <group>lateral_movement,smb,</group>
  </rule>

  <rule id="100201" level="12">
    <if_group>windows</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)wmic\s+/node:</field>
    <description>Lateral Movement: Remote WMI execution via wmic /node (T1047)</description>
    <mitre><id>T1047</id></mitre>
    <group>lateral_movement,wmi,</group>
  </rule>

  <rule id="100202" level="13">
    <if_group>windows</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(psexec|psexesvc)</field>
    <description>Lateral Movement: PsExec remote execution (T1569.002)</description>
    <mitre><id>T1569.002</id></mitre>
    <group>lateral_movement,psexec,</group>
  </rule>

  <rule id="100203" level="14">
    <if_group>windows</if_group>
    <field name="win.eventdata.serviceName" type="pcre2">(?i)PSEXESVC</field>
    <description>Lateral Movement CRITICAL: PSEXESVC service created (T1569.002)</description>
    <mitre><id>T1569.002</id></mitre>
    <group>lateral_movement,psexec,critical,</group>
  </rule>

  <rule id="100204" level="11">
    <if_group>windows</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(Enter-PSSession|Invoke-Command|New-PSSession).*-ComputerName</field>
    <description>Lateral Movement: PowerShell Remoting to remote host (T1021.006)</description>
    <mitre><id>T1021.006</id></mitre>
    <group>lateral_movement,winrm,powershell,</group>
  </rule>

  <rule id="100205" level="12">
    <if_group>windows</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)schtasks.*/s\s+\S+.*/create</field>
    <description>Lateral Movement: Remote scheduled task creation (T1053.005)</description>
    <mitre><id>T1053.005</id></mitre>
    <group>lateral_movement,schtasks,</group>
  </rule>

  <rule id="100206" level="12">
    <if_group>windows</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)sc\s+\\\\</field>
    <description>Lateral Movement: Remote service management via sc.exe (T1543.003)</description>
    <mitre><id>T1543.003</id></mitre>
    <group>lateral_movement,service,</group>
  </rule>

  <rule id="100207" level="10">
    <if_group>windows</if_group>
    <field name="win.eventdata.logonType">10</field>
    <field name="win.system.eventID">4624</field>
    <description>Lateral Movement: RDP Interactive Logon (LogonType 10) (T1021.001)</description>
    <mitre><id>T1021.001</id></mitre>
    <group>lateral_movement,rdp,</group>
  </rule>

  <rule id="100208" level="14">
    <if_group>windows</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(smbexec|wmiexec|atexec|dcomexec|secretsdump)</field>
    <description>Lateral Movement CRITICAL: Impacket tool detected (T1021.002)</description>
    <mitre><id>T1021.002</id></mitre>
    <group>lateral_movement,impacket,critical,</group>
  </rule>

  <!-- ===== LOLBINS (wazuh_lolbins) ===== -->

  <rule id="100100" level="10">
    <if_group>windows</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)certutil.*(urlcache|decode|encode)</field>
    <description>LOLBin: certutil used for download or decode (T1140/T1105)</description>
    <mitre><id>T1140</id><id>T1105</id></mitre>
    <group>lolbins,certutil,</group>
  </rule>

  <rule id="100101" level="12">
    <if_group>windows</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)mshta.*https?://</field>
    <description>LOLBin: mshta executing script from remote URL (T1218.005)</description>
    <mitre><id>T1218.005</id></mitre>
    <group>lolbins,mshta,</group>
  </rule>

  <rule id="100102" level="12">
    <if_group>windows</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)regsvr32.*(\/i|\/s).*https?://</field>
    <description>LOLBin: regsvr32 Squiblydoo loading remote script (T1218.010)</description>
    <mitre><id>T1218.010</id></mitre>
    <group>lolbins,regsvr32,</group>
  </rule>

  <rule id="100103" level="11">
    <if_group>windows</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)rundll32.*(javascript:|shell32\.dll|advpack\.dll)</field>
    <description>LOLBin: rundll32 executing suspicious script or DLL (T1218.011)</description>
    <mitre><id>T1218.011</id></mitre>
    <group>lolbins,rundll32,</group>
  </rule>

  <rule id="100104" level="10">
    <if_group>windows</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)wmic.*(process call create|shadowcopy delete|\/node:)</field>
    <description>LOLBin: wmic used for remote execution or shadow copy deletion (T1047)</description>
    <mitre><id>T1047</id></mitre>
    <group>lolbins,wmic,</group>
  </rule>

  <rule id="100105" level="11">
    <if_group>windows</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)bitsadmin.*(\/transfer|\/addfile)</field>
    <description>LOLBin: bitsadmin used for payload download (T1197)</description>
    <mitre><id>T1197</id></mitre>
    <group>lolbins,bitsadmin,</group>
  </rule>

  <rule id="100106" level="13">
    <if_group>windows</if_group>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)(cmd|powershell|wscript|cscript)\.exe</field>
    <field name="win.eventdata.image" type="pcre2">(?i)InstallUtil\.exe</field>
    <description>LOLBin: InstallUtil from shell - AppLocker bypass (T1218.004)</description>
    <mitre><id>T1218.004</id></mitre>
    <group>lolbins,installutil,</group>
  </rule>

  <rule id="100107" level="13">
    <if_group>windows</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)cmstp.*(\/ni|\/s|\/au)</field>
    <description>LOLBin: cmstp with suspicious flags - UAC bypass (T1218.003)</description>
    <mitre><id>T1218.003</id></mitre>
    <group>lolbins,cmstp,</group>
  </rule>

  <rule id="100108" level="11">
    <if_group>windows</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)msiexec.*https?://</field>
    <description>LOLBin: msiexec installing MSI from remote URL (T1218.007)</description>
    <mitre><id>T1218.007</id></mitre>
    <group>lolbins,msiexec,</group>
  </rule>

  <rule id="100109" level="15">
    <if_group>windows</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)mavinject</field>
    <description>LOLBin CRITICAL: mavinject detected - DLL injection (T1055.001)</description>
    <mitre><id>T1055.001</id></mitre>
    <group>lolbins,injection,critical,</group>
  </rule>

  <rule id="100110" level="12">
    <if_group>windows</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)powershell.*(-enc|-encodedcommand)</field>
    <description>LOLBin: PowerShell Base64 encoded command - AV bypass (T1059.001)</description>
    <mitre><id>T1059.001</id><id>T1027</id></mitre>
    <group>lolbins,powershell,obfuscation,</group>
  </rule>

  <rule id="100111" level="14">
    <if_group>windows</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(IEX|Invoke-Expression).*(WebClient|DownloadString|WebRequest)</field>
    <description>LOLBin: PowerShell download cradle - fileless execution (T1059.001/T1105)</description>
    <mitre><id>T1059.001</id><id>T1105</id></mitre>
    <group>lolbins,powershell,fileless,critical,</group>
  </rule>

</group>
