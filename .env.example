# ============================================================
# cyber-homelab — Variables d'environnement (exemple)
# Copier ce fichier en .env et remplir les vraies valeurs
# NE JAMAIS committer le fichier .env sur GitHub !
# ============================================================

# --- WAZUH API (https://192.168.56.10:55000) ---
# NOTE: WAZUH_USER/WAZUH_PASS = Wazuh API credentials (not the dashboard admin)
# Get API password: on Wazuh Manager VM → cat /usr/share/wazuh-indexer/opensearch-security/internal_users.yml
# Or reset via: sudo /usr/share/wazuh-indexer/plugins/opensearch-security/tools/wazuh-passwords-tool.sh -u wazuh -p <newpass>
WAZUH_HOST=192.168.56.10
WAZUH_PORT=55000
WAZUH_USER=admin
WAZUH_PASS=your_wazuh_api_password_here

# --- THEHIVE ---
THEHIVE_URL=http://127.0.0.1:9010
THEHIVE_API_KEY=your_thehive_api_key_here

# --- VirusTotal API (gratuit : 4 req/min, 500/jour) ---
# https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=your_vt_api_key_here

# --- AbuseIPDB (gratuit : 1000 req/jour) ---
# https://www.abuseipdb.com/api
ABUSEIPDB_API_KEY=your_abuseipdb_key_here

# --- Shodan (gratuit limité) ---
# https://account.shodan.io/
SHODAN_API_KEY=your_shodan_key_here

# --- MISP (optionnel, pour le module CTI) ---
MISP_URL=https://your-misp-instance.local
MISP_API_KEY=your_misp_key_here
MISP_VERIFY_SSL=false

# --- OpenCTI (optionnel) ---
OPENCTI_URL=https://your-opencti.local
OPENCTI_TOKEN=your_opencti_token_here

# --- ThreatFox / URLhaus (gratuit, pas de clé requise) ---
THREATFOX_API_KEY=anonymous

# --- Proxies (optionnel) ---
# HTTP_PROXY=http://proxy:8080
# HTTPS_PROXY=http://proxy:8080
