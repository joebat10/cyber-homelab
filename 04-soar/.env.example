# ─────────────────────────────────────────────────────────────────────────────
# Cyber-homelab SOAR stack — Environment Variables
# Copy this file to .env and change all values marked CHANGE_ME
# .env is in .gitignore — never commit real credentials
# ─────────────────────────────────────────────────────────────────────────────

# ── TheHive 5 ─────────────────────────────────────────────────────────────────
THEHIVE_VERSION=5.3
# WARNING: ports 9000/9001 are taken by cybergrc_minio — use 9010/9011
THEHIVE_PORT=9010
# Must be at least 32 chars
THEHIVE_SECRET=CHANGE_ME_thehive_secret_min_32_chars_xxxxxxxxxxxx

# ── Cortex 3 ──────────────────────────────────────────────────────────────────
CORTEX_VERSION=3.1.8
CORTEX_PORT=9011
CORTEX_SECRET=CHANGE_ME_cortex_secret_min_32_chars_xxxxxxxxxxxx

# ── MISP ──────────────────────────────────────────────────────────────────────
MISP_VERSION=latest
MISP_PORT=8443
MISP_ADMIN_EMAIL=admin@cyber-homelab.local
MISP_ADMIN_PASSWORD=CHANGE_ME_MISPadmin2024!
MISP_GPG_PASSWORD=CHANGE_ME_GPG_passphrase
# Must be exactly 32 chars
MISP_ENCRYPTION_KEY=CHANGE_ME_misp_enc_key_32chars__

# ── MISP — MySQL credentials ──────────────────────────────────────────────────
MISP_MYSQL_DATABASE=misp
MISP_MYSQL_USER=misp
MISP_MYSQL_PASSWORD=CHANGE_ME_misp_db_password
MISP_MYSQL_ROOT_PASSWORD=CHANGE_ME_misp_root_password

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ELASTICSEARCH_VERSION=7.17.15
# Heap size — 512m minimum; lower risks OOM on queries
ELASTICSEARCH_HEAP=512m

# ── JVM heap — TheHive & Cortex ───────────────────────────────────────────────
THEHIVE_JVM_OPTS=-Xms256m -Xmx512m
CORTEX_JVM_OPTS=-Xms256m -Xmx512m

# ── Cassandra ─────────────────────────────────────────────────────────────────
CASSANDRA_VERSION=4.1
# 512M is the practical minimum for Cassandra 4
CASSANDRA_MAX_HEAP=512M
CASSANDRA_HEAP_NEW=64M

# ── MySQL / Redis ─────────────────────────────────────────────────────────────
MYSQL_VERSION=8.0
REDIS_VERSION=7-alpine
# Must match the password set in the redis service command
REDIS_PASSWORD=CHANGE_ME_redis_password
